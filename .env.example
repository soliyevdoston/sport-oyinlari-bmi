# API
API_PORT=8080
API_HOST=0.0.0.0
API_PREFIX=/api/v1
# Comma-separated list. Supports wildcard. Examples:
# CORS_ORIGIN=*
# CORS_ORIGIN=http://localhost:*,https://your-domain.vercel.app
CORS_ORIGIN=*
JWT_ACCESS_SECRET=replace_me_access
JWT_REFRESH_SECRET=replace_me_refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aetherscore

# Sports Providers
SPORTS_PROVIDER_PRIMARY=thesportsdb
SPORTS_PROVIDER_FALLBACK=api-football
THESPORTSDB_API_KEY=
GUARDIAN_API_KEY=test
API_FOOTBALL_API_KEY=

# AI
AI_API_KEY=

AI_MODEL_TEXT=gpt-4.1-mini
AI_MODEL_VISION=gpt-4.1-mini

# Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# Payments
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYME_MERCHANT_ID=
CLICK_SERVICE_ID=
