generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
  TRIALING
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELED
}

enum MatchSide {
  HOME
  AWAY
}

enum FavoriteTargetType {
  TEAM
  SPORT
  LEAGUE
  MATCH
}

enum NotificationType {
  MATCH_REMINDER
  TEAM_ALERT
  SUBSCRIPTION_EVENT
  AI_ANALYSIS_COMPLETED
  PREMIUM_PROMPT
  SYSTEM
}

model User {
  id                String               @id @default(cuid())
  fullName          String
  email             String               @unique
  passwordHash      String
  role              UserRole             @default(USER)
  emailVerifiedAt   DateTime?
  favoriteSportId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  favoriteSport     Sport?               @relation(fields: [favoriteSportId], references: [id])
  refreshTokens     RefreshToken[]
  subscriptions     Subscription[]
  payments          PaymentTransaction[]
  favorites         Favorite[]
  aiPredictions     AiPrediction[]
  uploadedAssets    UploadedAsset[]
  screenshotAnalyses ScreenshotAnalysis[]
  notifications     Notification[]
  adminLogs         AdminLog[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  ip         String?
  userAgent  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(TRIALING)
  provider              String
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentTransactions   PaymentTransaction[]

  @@index([userId])
  @@index([status])
}

model PaymentTransaction {
  id               String        @id @default(cuid())
  userId           String
  subscriptionId   String?
  provider         String
  providerTxnId    String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("USD")
  status           PaymentStatus @default(PENDING)
  metadata         Json?
  createdAt        DateTime      @default(now())

  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, providerTxnId])
  @@index([userId, createdAt])
}

model Sport {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  leagues        League[]
  teams          Team[]
  players        Player[]
  matches        Match[]
  users          User[]
}

model League {
  id           String   @id @default(cuid())
  sportId      String
  providerRef  String?
  slug         String
  name         String
  country      String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sport        Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  teams        Team[]
  matches      Match[]

  @@unique([sportId, slug])
  @@index([sportId])
}

model Team {
  id           String   @id @default(cuid())
  sportId      String
  leagueId     String?
  providerRef  String?
  name         String
  shortName    String?
  logoUrl      String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sport            Sport     @relation(fields: [sportId], references: [id], onDelete: Cascade)
  league           League?   @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  homeMatches      Match[]   @relation("HomeTeam")
  awayMatches      Match[]   @relation("AwayTeam")
  matchEvents      MatchEvent[]
  players          Player[]

  @@index([sportId])
  @@index([leagueId])
}

model Player {
  id           String   @id @default(cuid())
  sportId      String
  teamId       String?
  providerRef  String?
  name         String
  position     String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sport        Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  team         Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([sportId])
  @@index([teamId])
}

model Match {
  id            String      @id @default(cuid())
  sportId       String
  leagueId      String
  homeTeamId    String
  awayTeamId    String
  providerRef   String?
  status        MatchStatus @default(SCHEDULED)
  startTime     DateTime
  venue         String?
  scoreHome     Int?
  scoreAway     Int?
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sport                 Sport                @relation(fields: [sportId], references: [id], onDelete: Cascade)
  league                League               @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam              Team                 @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam              Team                 @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  statistics            MatchStatistic[]
  events                MatchEvent[]
  ticketLinks           TicketLink[]
  predictions           AiPrediction[]
  screenshotAnalyses    ScreenshotAnalysis[]

  @@index([sportId, leagueId, startTime])
  @@index([status, startTime])
}

model MatchStatistic {
  id          String    @id @default(cuid())
  matchId     String
  side        MatchSide
  statKey     String
  statValue   String
  createdAt   DateTime  @default(now())

  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([statKey])
}

model MatchEvent {
  id          String    @id @default(cuid())
  matchId     String
  minute      Int?
  eventType   String
  teamId      String?
  playerName  String?
  payload     Json?
  createdAt   DateTime  @default(now())

  match       Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team        Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([matchId, minute])
}

model TicketLink {
  id               String   @id @default(cuid())
  matchId          String
  providerName     String
  providerLogoUrl  String?
  url              String
  isTrusted        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  match            Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model Favorite {
  id          String             @id @default(cuid())
  userId      String
  targetType  FavoriteTargetType
  targetId    String
  createdAt   DateTime           @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@index([userId, targetType])
}

model AiPrediction {
  id             String   @id @default(cuid())
  userId         String?
  matchId        String
  modelName      String
  inputSnapshot  Json
  output         Json
  confidence     Float?
  createdAt      DateTime @default(now())

  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId, createdAt])
  @@index([userId])
}

model UploadedAsset {
  id              String   @id @default(cuid())
  userId          String
  storageProvider String
  storageKey      String
  mimeType        String
  sizeBytes       Int
  originalName    String
  createdAt       DateTime @default(now())

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses        ScreenshotAnalysis[]

  @@index([userId, createdAt])
}

model ScreenshotAnalysis {
  id             String   @id @default(cuid())
  userId         String
  assetId        String
  linkedMatchId  String?
  note           String?
  modelName      String
  result         Json
  confidence     Float?
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset          UploadedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  linkedMatch    Match?        @relation(fields: [linkedMatchId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([linkedMatchId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  type        NotificationType @default(SYSTEM)
  title       String
  body        String
  metadata    Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AdminLog {
  id           String   @id @default(cuid())
  adminUserId  String
  action       String
  entityType   String
  entityId     String?
  payload      Json?
  createdAt    DateTime @default(now())

  adminUser    User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, createdAt])
}
