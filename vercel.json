{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/api/[...path].ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build -w packages/shared && npm run build -w apps/web",
        "distDir": "apps/web/dist"
      }
    }
  ],
  "functions": {
    "apps/api/api/[...path].ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/api/api/[...path].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
